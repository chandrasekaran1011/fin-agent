# ── LLM Provider ──────────────────────────────────────
LLM_PROVIDER=azure                        # "azure" | "openai"

# Azure OpenAI (used when LLM_PROVIDER=azure)
AZURE_OPENAI_API_KEY=your-azure-api-key
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Databases ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

DATABASE_URL=postgresql://postgres:password@localhost:5432/finagent

# FAISS index storage path (local filesystem)
FAISS_INDEX_PATH=./data/faiss

# ── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_LLM_PROVIDER=azure
NODE_ENV=development
